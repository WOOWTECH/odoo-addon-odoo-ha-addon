<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!--
        Portal Templates for Home Assistant Integration
        Uses native Odoo 18 portal patterns (portal_docs_entry, portal_table,
        portal_sidebar, portal_searchbar, portal_breadcrumbs).

        Routes (from controllers/portal.py):
        - /my/ha                                    Hub: Instance card grid
        - /my/ha/<instance_id>                      Instance detail: 3-tab view
        - /my/ha/<instance_id>/entity/<entity_id>   Entity detail + OWL control
        - /my/ha/<instance_id>/group/<group_id>     Group detail + OWL
        - /my/ha/<instance_id>/device/<device_id>   Device detail

        OWL Components (from static/src/portal/):
        - PortalEntityInfo: Entity info card with polling
        - PortalGroupInfo: Group info with entities table and stats
        - PortalEntityController: Device control UI (only for 'control' permission)
    -->

    <!-- ========================================
         Portal /my Home Page Integration
         ======================================== -->

    <template id="portal_my_home_ha" name="Portal My Home - Home Assistant"
              inherit_id="portal.portal_my_home" customize_show="True" priority="50">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="before">
            <t t-set="portal_service_category_enable" t-value="True"/>
        </xpath>
        <div id="portal_service_category" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="icon" t-value="'/odoo_ha_addon/static/src/img/ha-home.svg'"/>
                <t t-set="title">Home Assistant</t>
                <t t-set="url" t-value="'/my/ha'"/>
                <t t-set="text">View and control your shared smart home devices</t>
                <t t-set="placeholder_count" t-value="'ha_share_count'"/>
            </t>
        </div>
    </template>

    <!-- ========================================
         Breadcrumb Integration
         ======================================== -->

    <template id="portal_breadcrumbs_ha" name="Portal Breadcrumbs - Home Assistant"
              inherit_id="portal.portal_breadcrumbs" priority="40">
        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
            <!-- Hub page (active) -->
            <li t-if="page_name == 'portal_my_ha'" class="breadcrumb-item active">
                Home Assistant
            </li>

            <!-- Instance, entity, group, device pages: HA link -->
            <li t-if="page_name in ('portal_my_ha_instance', 'portal_entity', 'portal_entity_group', 'portal_device')"
                class="breadcrumb-item">
                <a href="/my/ha">Home Assistant</a>
            </li>

            <!-- Instance detail (active) -->
            <li t-if="page_name == 'portal_my_ha_instance'" class="breadcrumb-item active">
                <t t-out="instance.name"/>
            </li>

            <!-- Entity, group, device pages: Instance link -->
            <li t-if="page_name in ('portal_entity', 'portal_entity_group', 'portal_device') and instance"
                class="breadcrumb-item">
                <a t-attf-href="/my/ha/#{instance.id}"><t t-out="instance.name"/></a>
            </li>

            <!-- Entity detail (active) -->
            <li t-if="page_name == 'portal_entity'" class="breadcrumb-item active">
                <t t-out="entity.name or entity.entity_id"/>
            </li>

            <!-- Group detail (active) -->
            <li t-if="page_name == 'portal_entity_group'" class="breadcrumb-item active">
                <t t-out="group.name"/>
            </li>

            <!-- Device detail (active) -->
            <li t-if="page_name == 'portal_device'" class="breadcrumb-item active">
                <t t-out="device.name_by_user or device.name"/>
            </li>
        </xpath>
    </template>

    <!-- ========================================
         /my/ha Hub Page (Instance List)
         ======================================== -->

    <template id="portal_my_ha" name="My Home Assistant Instances">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Home Assistant</t>
            </t>

            <!-- Instance Cards -->
            <t t-if="instances">
                <div class="o_portal_docs row g-2">
                    <t t-foreach="instances" t-as="inst">
                        <div class="o_portal_index_card col-md-6 col-lg-4">
                            <a t-attf-href="/my/ha/#{inst['instance'].id}"
                               class="d-flex gap-2 gap-md-3 py-3 pe-2 px-md-3 h-100 rounded text-decoration-none bg-100">
                                <div class="o_portal_icon d-block align-self-start">
                                    <img src="/odoo_ha_addon/static/src/img/ha-instance.svg"
                                         alt="HA Instance" width="64" height="64"/>
                                </div>
                                <div>
                                    <div class="mt-0 mb-1 fs-5 fw-normal lh-1">
                                        <span><t t-out="inst['instance'].name"/></span>
                                    </div>
                                    <div class="opacity-75">
                                        <t t-out="inst['entity_count']"/> entities,
                                        <t t-out="inst['group_count']"/> groups,
                                        <t t-out="inst['device_count']"/> devices
                                    </div>
                                </div>
                            </a>
                        </div>
                    </t>
                </div>
            </t>

            <!-- Empty State -->
            <t t-else="">
                <div class="alert alert-warning" role="alert">
                    No Home Assistant devices shared with you yet.
                </div>
            </t>
        </t>
    </template>

    <!-- ========================================
         /my/ha/<instance_id> Instance Detail
         ======================================== -->

    <template id="portal_my_ha_instance" name="My HA Instance Detail">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title" t-value="instance.name"/>
            </t>

            <!-- Tab Navigation -->
            <ul class="nav nav-tabs mb-3" role="tablist">
                <li class="nav-item" role="presentation">
                    <a t-attf-class="nav-link #{active_tab == 'entities' and 'active' or ''}"
                       t-attf-href="/my/ha/#{instance.id}?tab=entities">
                        Entities
                        <span class="badge text-bg-secondary ms-1"><t t-out="entity_count"/></span>
                    </a>
                </li>
                <li class="nav-item" role="presentation">
                    <a t-attf-class="nav-link #{active_tab == 'groups' and 'active' or ''}"
                       t-attf-href="/my/ha/#{instance.id}?tab=groups">
                        Groups
                        <span class="badge text-bg-secondary ms-1"><t t-out="group_count"/></span>
                    </a>
                </li>
                <li class="nav-item" role="presentation">
                    <a t-attf-class="nav-link #{active_tab == 'devices' and 'active' or ''}"
                       t-attf-href="/my/ha/#{instance.id}?tab=devices">
                        Devices
                        <span class="badge text-bg-secondary ms-1"><t t-out="device_count"/></span>
                    </a>
                </li>
            </ul>

            <!-- ===== Entities Tab ===== -->
            <t t-if="active_tab == 'entities'">
                <t t-if="not entities">
                    <div class="alert alert-warning">No entities shared from this instance.</div>
                </t>
                <t t-if="entities" t-call="portal.portal_table">
                    <thead>
                        <tr class="active">
                            <th>Name</th>
                            <th>Domain</th>
                            <th class="text-end">Area</th>
                            <th class="text-end">State</th>
                        </tr>
                    </thead>
                    <t t-foreach="entities" t-as="entity">
                        <tr>
                            <td>
                                <a t-attf-href="/my/ha/#{instance.id}/entity/#{entity.id}">
                                    <t t-out="entity.name or entity.entity_id"/>
                                </a>
                            </td>
                            <td>
                                <span class="badge rounded-pill text-bg-info">
                                    <t t-out="entity.domain"/>
                                </span>
                            </td>
                            <td class="text-end">
                                <t t-if="entity.area_id"><t t-out="entity.area_id.name"/></t>
                            </td>
                            <td class="text-end">
                                <span t-attf-class="badge rounded-pill text-bg-#{entity.entity_state in ('on', 'open', 'active', 'home') and 'success' or entity.entity_state in ('off', 'closed', 'inactive') and 'secondary' or 'info'}">
                                    <t t-out="entity.entity_state"/>
                                </span>
                            </td>
                        </tr>
                    </t>
                </t>
            </t>

            <!-- ===== Groups Tab ===== -->
            <t t-if="active_tab == 'groups'">
                <t t-if="not groups">
                    <div class="alert alert-warning">No groups shared from this instance.</div>
                </t>
                <t t-if="groups" t-call="portal.portal_table">
                    <thead>
                        <tr class="active">
                            <th>Name</th>
                            <th>Description</th>
                            <th class="text-end">Entities</th>
                        </tr>
                    </thead>
                    <t t-foreach="groups" t-as="group">
                        <tr>
                            <td>
                                <a t-attf-href="/my/ha/#{instance.id}/group/#{group.id}">
                                    <t t-out="group.name"/>
                                </a>
                            </td>
                            <td>
                                <t t-if="group.description">
                                    <t t-out="group.description[:60]"/>
                                    <t t-if="len(group.description or '') > 60">...</t>
                                </t>
                            </td>
                            <td class="text-end">
                                <span class="badge text-bg-secondary">
                                    <t t-out="group.entity_count"/>
                                </span>
                            </td>
                        </tr>
                    </t>
                </t>
            </t>

            <!-- ===== Devices Tab ===== -->
            <t t-if="active_tab == 'devices'">
                <t t-if="not devices">
                    <div class="alert alert-warning">No devices shared from this instance.</div>
                </t>
                <t t-if="devices" t-call="portal.portal_table">
                    <thead>
                        <tr class="active">
                            <th>Name</th>
                            <th>Manufacturer</th>
                            <th class="text-end">Model</th>
                            <th class="text-end">Entities</th>
                        </tr>
                    </thead>
                    <t t-foreach="devices" t-as="device">
                        <tr>
                            <td>
                                <a t-attf-href="/my/ha/#{instance.id}/device/#{device.id}">
                                    <t t-out="device.name_by_user or device.name"/>
                                </a>
                            </td>
                            <td><t t-out="device.manufacturer or ''"/></td>
                            <td class="text-end"><t t-out="device.model or ''"/></td>
                            <td class="text-end">
                                <span class="badge text-bg-secondary">
                                    <t t-out="device.entity_count"/>
                                </span>
                            </td>
                        </tr>
                    </t>
                </t>
            </t>
        </t>
    </template>

    <!-- ========================================
         Entity Detail Page (portal_sidebar)
         ======================================== -->

    <template id="portal_entity_detail" name="Portal Entity Detail"
              inherit_id="portal.portal_sidebar" primary="True">
        <xpath expr="//div[hasclass('o_portal_sidebar')]" position="inside">
            <div class="row o_portal_entity_sidebar">
                <!-- Sidebar -->
                <t t-call="portal.portal_record_sidebar">
                    <t t-set="classes" t-value="'col-lg-4 col-xxl-3 d-print-none'"/>
                    <t t-set="entries">
                        <div class="d-flex flex-wrap flex-column gap-4">
                            <!-- Status -->
                            <div class="d-flex flex-column gap-1">
                                <span class="text-muted small">Status</span>
                                <span t-attf-class="badge rounded-pill text-bg-#{entity.entity_state in ('on', 'open', 'active', 'home') and 'success' or entity.entity_state in ('off', 'closed', 'inactive') and 'secondary' or 'info'}">
                                    <t t-out="entity.entity_state"/>
                                </span>
                            </div>
                            <!-- Domain -->
                            <div class="d-flex flex-column gap-1">
                                <span class="text-muted small">Domain</span>
                                <span class="badge rounded-pill text-bg-info"><t t-out="entity.domain"/></span>
                            </div>
                            <!-- Area -->
                            <t t-if="entity.area_id">
                                <div class="d-flex flex-column gap-1">
                                    <span class="text-muted small">Area</span>
                                    <span><t t-out="entity.area_id.name"/></span>
                                </div>
                            </t>
                            <!-- Last Changed -->
                            <t t-if="entity.last_changed">
                                <div class="d-flex flex-column gap-1">
                                    <span class="text-muted small">Last Changed</span>
                                    <span t-field="entity.last_changed" t-options='{"widget": "datetime"}'/>
                                </div>
                            </t>
                            <!-- Entity ID -->
                            <div class="d-flex flex-column gap-1">
                                <span class="text-muted small">Entity ID</span>
                                <span class="text-break small"><t t-out="entity.entity_id"/></span>
                            </div>
                            <!-- Permission -->
                            <div class="d-flex flex-column gap-1">
                                <span class="text-muted small">Permission</span>
                                <span t-attf-class="badge rounded-pill text-bg-#{permission == 'control' and 'success' or 'secondary'}">
                                    <t t-out="permission"/>
                                </span>
                            </div>
                            <!-- Nav links -->
                            <div class="d-flex align-items-center flex-grow-1 p-0" t-ignore="true" role="complementary">
                                <ul class="nav flex-column">
                                    <li class="nav-item">
                                        <a class="nav-link p-0" href="#entity_control">Control</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link p-0" href="#card_header">Details</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link p-0" href="#discussion">Discussion</a>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </t>
                </t>

                <!-- Main Content -->
                <div id="entity_content" class="o_portal_content col-12 col-lg-8 col-xxl-9">
                    <div id="card">
                        <div id="card_header" data-anchor="true">
                            <h3><t t-out="entity.name or entity.entity_id"/></h3>
                        </div>
                        <div id="card_body">

                            <!-- OWL Control (inline, primary content) -->
                            <div id="entity_control" data-anchor="true">
                                <t t-if="permission == 'control' and entity.domain in controllable_domains">
                                    <owl-component
                                        name="odoo_ha_addon.PortalEntityController"
                                        t-att-props="json.dumps({
                                            'entity': {
                                                'id': entity.id,
                                                'entity_id': entity.entity_id,
                                                'name': entity.name,
                                                'domain': entity.domain,
                                                'entity_state': entity.entity_state,
                                                'attributes': sanitize_attrs(entity.attributes),
                                            },
                                            'permission': permission,
                                            'stateUrl': '/my/ha/%d/entity/%d/state' % (instance.id, entity.id),
                                            'serviceUrl': '/my/ha/%d/entity/%d/service' % (instance.id, entity.id),
                                        })"/>
                                </t>
                            </div>

                            <!-- OWL Entity Info (live polling: state, attributes) -->
                            <div class="mt-3">
                                <owl-component
                                    name="odoo_ha_addon.PortalEntityInfo"
                                    t-att-props="json.dumps({
                                        'entity': {
                                            'id': entity.id,
                                            'entity_id': entity.entity_id,
                                            'name': entity.name,
                                            'domain': entity.domain,
                                            'entity_state': entity.entity_state,
                                            'last_changed': str(entity.last_changed) if entity.last_changed else None,
                                            'attributes': sanitize_attrs(entity.attributes),
                                            'area_name': entity.area_id.name if entity.area_id else None,
                                        },
                                        'stateUrl': '/my/ha/%d/entity/%d/state' % (instance.id, entity.id),
                                    })"/>
                            </div>

                            <!-- Static Attributes (collapsed, supplementary) -->
                            <t t-set="attrs" t-value="sanitize_attrs(entity.attributes)"/>
                            <t t-if="attrs">
                                <details class="mt-3">
                                    <summary class="text-muted small">
                                        <i class="fa fa-cogs me-1"/>Raw Attributes
                                    </summary>
                                    <table class="table table-sm table-striped mt-2">
                                        <thead>
                                            <tr>
                                                <th>Attribute</th>
                                                <th>Value</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="attrs.items()" t-as="attr">
                                                <tr>
                                                    <td><t t-out="attr[0]"/></td>
                                                    <td><t t-out="attr[1]"/></td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </details>
                            </t>

                        </div>
                    </div>

                    <hr/>
                    <div id="discussion" data-anchor="true">
                        <h3>Discussion</h3>
                        <t t-call="portal.message_thread">
                            <t t-set="object" t-value="entity"/>
                            <t t-set="token" t-value="entity.access_token"/>
                        </t>
                    </div>
                </div>
            </div>
        </xpath>
    </template>

    <!-- ========================================
         Group Detail Page (portal_sidebar)
         ======================================== -->

    <template id="portal_group_detail" name="Portal Group Detail"
              inherit_id="portal.portal_sidebar" primary="True">
        <xpath expr="//div[hasclass('o_portal_sidebar')]" position="inside">
            <div class="row o_portal_group_sidebar">
                <!-- Sidebar -->
                <t t-call="portal.portal_record_sidebar">
                    <t t-set="classes" t-value="'col-lg-4 col-xxl-3 d-print-none'"/>
                    <t t-set="entries">
                        <div class="d-flex flex-wrap flex-column gap-4">
                            <!-- Entity Count -->
                            <div class="d-flex flex-column gap-1">
                                <span class="text-muted small">Entity Count</span>
                                <span class="badge text-bg-secondary"><t t-out="group.entity_count"/></span>
                            </div>
                            <!-- Description -->
                            <t t-if="group.description">
                                <div class="d-flex flex-column gap-1">
                                    <span class="text-muted small">Description</span>
                                    <span class="small"><t t-out="group.description"/></span>
                                </div>
                            </t>
                            <!-- Permission -->
                            <div class="d-flex flex-column gap-1">
                                <span class="text-muted small">Permission</span>
                                <span t-attf-class="badge rounded-pill text-bg-#{permission == 'control' and 'success' or 'secondary'}">
                                    <t t-out="permission"/>
                                </span>
                            </div>
                            <!-- Nav links -->
                            <div class="d-flex align-items-center flex-grow-1 p-0" t-ignore="true" role="complementary">
                                <ul class="nav flex-column">
                                    <li class="nav-item">
                                        <a class="nav-link p-0" href="#card_header">Details</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link p-0" href="#group_entities">Entities</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link p-0" href="#discussion">Discussion</a>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </t>
                </t>

                <!-- Main Content -->
                <div id="group_content" class="o_portal_content col-12 col-lg-8 col-xxl-9">
                    <div id="card">
                        <div id="card_header" data-anchor="true">
                            <h3><t t-out="group.name"/></h3>
                            <t t-if="group.description">
                                <p class="text-muted"><t t-out="group.description"/></p>
                            </t>
                        </div>
                        <div id="card_body">
                            <!-- Entities in Group -->
                            <div id="group_entities" data-anchor="true">
                                <h5 class="mt-3">Entities</h5>
                                <t t-if="group.entity_ids">
                                    <table class="table table-sm table-striped">
                                        <thead>
                                            <tr>
                                                <th>Name</th>
                                                <th>Domain</th>
                                                <th class="text-end">State</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="group.entity_ids" t-as="entity">
                                                <tr>
                                                    <td><t t-out="entity.name or entity.entity_id"/></td>
                                                    <td>
                                                        <span class="badge rounded-pill text-bg-info">
                                                            <t t-out="entity.domain"/>
                                                        </span>
                                                    </td>
                                                    <td class="text-end">
                                                        <span t-attf-class="badge rounded-pill text-bg-#{entity.entity_state in ('on', 'open', 'active', 'home') and 'success' or entity.entity_state in ('off', 'closed', 'inactive') and 'secondary' or 'info'}">
                                                            <t t-out="entity.entity_state"/>
                                                        </span>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </t>
                                <t t-else="">
                                    <p class="text-muted">No entities in this group.</p>
                                </t>
                            </div>
                        </div>
                    </div>

                    <!-- OWL Group Info Component -->
                    <div class="mt-3">
                        <owl-component
                            name="odoo_ha_addon.PortalGroupInfo"
                            t-att-props="json.dumps({
                                'group': {
                                    'id': group.id,
                                    'name': group.name,
                                    'entities': [],
                                },
                                'permission': permission,
                                'controllableDomains': controllable_domains,
                                'stateUrl': '/my/ha/%d/group/%d/state' % (instance.id, group.id),
                                'serviceUrl': '/my/ha/%d/entity/0/service' % (instance.id,),
                            })"/>
                    </div>

                    <hr/>
                    <div id="discussion" data-anchor="true">
                        <h3>Discussion</h3>
                        <t t-call="portal.message_thread">
                            <t t-set="object" t-value="group"/>
                            <t t-set="token" t-value="group.access_token"/>
                        </t>
                    </div>
                </div>
            </div>
        </xpath>
    </template>

    <!-- ========================================
         Device Detail Page (portal_sidebar)
         ======================================== -->

    <template id="portal_device_detail" name="Portal Device Detail"
              inherit_id="portal.portal_sidebar" primary="True">
        <xpath expr="//div[hasclass('o_portal_sidebar')]" position="inside">
            <div class="row o_portal_device_sidebar">
                <!-- Sidebar -->
                <t t-call="portal.portal_record_sidebar">
                    <t t-set="classes" t-value="'col-lg-4 col-xxl-3 d-print-none'"/>
                    <t t-set="entries">
                        <div class="d-flex flex-wrap flex-column gap-4">
                            <!-- Manufacturer -->
                            <t t-if="device.manufacturer">
                                <div class="d-flex flex-column gap-1">
                                    <span class="text-muted small">Manufacturer</span>
                                    <span><t t-out="device.manufacturer"/></span>
                                </div>
                            </t>
                            <!-- Model -->
                            <t t-if="device.model">
                                <div class="d-flex flex-column gap-1">
                                    <span class="text-muted small">Model</span>
                                    <span><t t-out="device.model"/></span>
                                </div>
                            </t>
                            <!-- Area -->
                            <t t-if="device.area_id">
                                <div class="d-flex flex-column gap-1">
                                    <span class="text-muted small">Area</span>
                                    <span><t t-out="device.area_id.name"/></span>
                                </div>
                            </t>
                            <!-- Entity Count -->
                            <div class="d-flex flex-column gap-1">
                                <span class="text-muted small">Entities</span>
                                <span class="badge text-bg-secondary"><t t-out="len(entities)"/></span>
                            </div>
                            <!-- Permission -->
                            <div class="d-flex flex-column gap-1">
                                <span class="text-muted small">Permission</span>
                                <span t-attf-class="badge rounded-pill text-bg-#{permission == 'control' and 'success' or 'secondary'}">
                                    <t t-out="permission"/>
                                </span>
                            </div>
                            <!-- Nav links -->
                            <div class="d-flex align-items-center flex-grow-1 p-0" t-ignore="true" role="complementary">
                                <ul class="nav flex-column">
                                    <li class="nav-item">
                                        <a class="nav-link p-0" href="#card_header">Details</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link p-0" href="#device_entities">Entities</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link p-0" href="#discussion">Discussion</a>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </t>
                </t>

                <!-- Main Content -->
                <div id="device_content" class="o_portal_content col-12 col-lg-8 col-xxl-9">
                    <div id="card">
                        <div id="card_header" data-anchor="true">
                            <h3><t t-out="device.name_by_user or device.name"/></h3>
                        </div>
                        <div id="card_body">
                            <!-- Device Info -->
                            <dl class="row mb-3">
                                <t t-if="device.manufacturer">
                                    <dt class="col-sm-4">Manufacturer</dt>
                                    <dd class="col-sm-8"><t t-out="device.manufacturer"/></dd>
                                </t>
                                <t t-if="device.model">
                                    <dt class="col-sm-4">Model</dt>
                                    <dd class="col-sm-8"><t t-out="device.model"/></dd>
                                </t>
                                <t t-if="device.area_id">
                                    <dt class="col-sm-4">Area</dt>
                                    <dd class="col-sm-8"><t t-out="device.area_id.name"/></dd>
                                </t>
                            </dl>

                            <!-- Entities List -->
                            <div id="device_entities" data-anchor="true">
                                <h5>Entities</h5>
                                <t t-if="entities">
                                    <table class="table table-sm table-striped">
                                        <thead>
                                            <tr>
                                                <th>Name</th>
                                                <th>Domain</th>
                                                <th class="text-end">State</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="entities" t-as="entity">
                                                <tr>
                                                    <td><t t-out="entity.name or entity.entity_id"/></td>
                                                    <td>
                                                        <span class="badge rounded-pill text-bg-info">
                                                            <t t-out="entity.domain"/>
                                                        </span>
                                                    </td>
                                                    <td class="text-end">
                                                        <span t-attf-class="badge rounded-pill text-bg-#{entity.entity_state in ('on', 'open', 'active', 'home') and 'success' or entity.entity_state in ('off', 'closed', 'inactive') and 'secondary' or 'info'}">
                                                            <t t-out="entity.entity_state"/>
                                                        </span>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </t>
                                <t t-else="">
                                    <p class="text-muted">No entities in this device.</p>
                                </t>
                            </div>
                        </div>
                    </div>

                    <!-- OWL Controls for Device Entities -->
                    <t t-if="permission == 'control'">
                        <t t-foreach="entities" t-as="entity">
                            <t t-if="entity.domain in controllable_domains">
                                <div class="mt-2">
                                    <owl-component
                                        name="odoo_ha_addon.PortalEntityController"
                                        t-att-props="json.dumps({
                                            'entity': {
                                                'id': entity.id,
                                                'entity_id': entity.entity_id,
                                                'name': entity.name,
                                                'domain': entity.domain,
                                                'entity_state': entity.entity_state,
                                                'attributes': sanitize_attrs(entity.attributes),
                                            },
                                            'permission': permission,
                                            'stateUrl': '/my/ha/%d/entity/%d/state' % (instance.id, entity.id),
                                            'serviceUrl': '/my/ha/%d/entity/%d/service' % (instance.id, entity.id),
                                        })"/>
                                </div>
                            </t>
                        </t>
                    </t>

                    <hr/>
                    <div id="discussion" data-anchor="true">
                        <h3>Discussion</h3>
                        <t t-call="portal.message_thread">
                            <t t-set="object" t-value="device"/>
                            <t t-set="token" t-value="device.access_token"/>
                        </t>
                    </div>
                </div>
            </div>
        </xpath>
    </template>

    <!-- ========================================
         Error Pages
         ======================================== -->

    <template id="portal_error_403" name="Portal Access Denied">
        <t t-call="portal.portal_layout">
            <t t-set="no_breadcrumbs" t-value="True"/>
            <div class="container py-5">
                <div class="row justify-content-center">
                    <div class="col-md-8 col-lg-6">
                        <div class="card border-danger">
                            <div class="card-body text-center py-5">
                                <div class="mb-4">
                                    <i class="fa fa-lock fa-4x text-danger"></i>
                                </div>
                                <h2 class="card-title text-danger mb-3">Access Denied</h2>
                                <p class="card-text text-muted mb-4">
                                    You do not have permission to access this resource.
                                    Please contact the owner to request access.
                                </p>
                                <a href="/my/ha" class="btn btn-light">
                                    Back to Home Assistant
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <template id="portal_error_404" name="Portal Not Found">
        <t t-call="portal.portal_layout">
            <t t-set="no_breadcrumbs" t-value="True"/>
            <div class="container py-5">
                <div class="row justify-content-center">
                    <div class="col-md-8 col-lg-6">
                        <div class="card border-warning">
                            <div class="card-body text-center py-5">
                                <div class="mb-4">
                                    <i class="fa fa-question-circle fa-4x text-warning"></i>
                                </div>
                                <h2 class="card-title text-warning mb-3">Not Found</h2>
                                <p class="card-text text-muted mb-4">
                                    The requested resource does not exist or has been removed.
                                    Please check the link and try again.
                                </p>
                                <a href="/my/ha" class="btn btn-light">
                                    Back to Home Assistant
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

</odoo>
