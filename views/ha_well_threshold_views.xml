<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- ============================================
         WELL IEQ Threshold - Actions
         ============================================ -->
    <record id="ha_well_threshold_action" model="ir.actions.act_window">
        <field name="name">WELL IEQ Monitor</field>
        <field name="res_model">ha.well.threshold</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No WELL IEQ thresholds configured yet
            </p>
            <p>
                Create WELL v2 compliance thresholds to monitor indoor environmental quality
                parameters such as CO&#x2082;, PM2.5, temperature, humidity, illuminance, and noise.
            </p>
        </field>
    </record>

    <!-- ============================================
         WELL IEQ Threshold - List View
         ============================================ -->
    <record id="ha_well_threshold_view_list" model="ir.ui.view">
        <field name="name">ha.well.threshold.list</field>
        <field name="model">ha.well.threshold</field>
        <field name="arch" type="xml">
            <list string="WELL IEQ Thresholds" decoration-danger="compliance_status == 'non_compliant'" decoration-success="compliance_status == 'compliant'" decoration-warning="compliance_status == 'warning'" decoration-muted="compliance_status == 'no_data'">
                <field name="name"/>
                <field name="well_feature"/>
                <field name="parameter_type"/>
                <field name="min_value"/>
                <field name="max_value"/>
                <field name="unit"/>
                <field name="last_value"/>
                <field name="compliance_status" widget="badge" decoration-danger="compliance_status == 'non_compliant'" decoration-success="compliance_status == 'compliant'" decoration-warning="compliance_status == 'warning'" decoration-muted="compliance_status == 'no_data'"/>
                <field name="entity_id" optional="show"/>
                <field name="instance_id" optional="hide"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- ============================================
         WELL IEQ Threshold - Form View
         ============================================ -->
    <record id="ha_well_threshold_view_form" model="ir.ui.view">
        <field name="name">ha.well.threshold.form</field>
        <field name="model">ha.well.threshold</field>
        <field name="arch" type="xml">
            <form string="WELL IEQ Threshold">
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="e.g. CO2 Level"/>
                        </h1>
                    </div>
                    <group>
                        <group string="WELL Standard">
                            <field name="well_feature"/>
                            <field name="parameter_type"/>
                            <field name="unit"/>
                        </group>
                        <group string="Threshold Range">
                            <field name="min_value"/>
                            <field name="max_value"/>
                        </group>
                    </group>
                    <group>
                        <group string="Home Assistant Link">
                            <field name="instance_id"/>
                            <field name="entity_id" domain="[('ha_instance_id', '=', instance_id)]"/>
                        </group>
                        <group string="Current Status">
                            <field name="last_value"/>
                            <field name="compliance_status" widget="badge" decoration-danger="compliance_status == 'non_compliant'" decoration-success="compliance_status == 'compliant'" decoration-warning="compliance_status == 'warning'" decoration-muted="compliance_status == 'no_data'"/>
                        </group>
                    </group>
                    <group>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================
         WELL IEQ Threshold - Kanban View
         ============================================ -->
    <record id="ha_well_threshold_view_kanban" model="ir.ui.view">
        <field name="name">ha.well.threshold.kanban</field>
        <field name="model">ha.well.threshold</field>
        <field name="arch" type="xml">
            <kanban default_group_by="well_feature" class="o_kanban_small_column">
                <field name="name"/>
                <field name="well_feature"/>
                <field name="parameter_type"/>
                <field name="last_value"/>
                <field name="compliance_status"/>
                <field name="min_value"/>
                <field name="max_value"/>
                <field name="unit"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top mb-0">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <div t-attf-class="badge #{record.compliance_status.raw_value == 'compliant' ? 'text-bg-success' : record.compliance_status.raw_value == 'non_compliant' ? 'text-bg-danger' : record.compliance_status.raw_value == 'warning' ? 'text-bg-warning' : 'text-bg-secondary'}">
                                    <field name="compliance_status"/>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <div>
                                    <strong>Reading: </strong>
                                    <field name="last_value"/>
                                    <t t-if="record.unit.raw_value"> <field name="unit"/></t>
                                </div>
                                <div class="text-muted">
                                    Range:
                                    <t t-if="record.min_value.raw_value"><field name="min_value"/></t>
                                    <t t-if="record.min_value.raw_value and record.max_value.raw_value"> - </t>
                                    <t t-if="record.max_value.raw_value"><field name="max_value"/></t>
                                    <t t-if="record.unit.raw_value"> <field name="unit"/></t>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ============================================
         WELL IEQ Threshold - Search View
         ============================================ -->
    <record id="ha_well_threshold_view_search" model="ir.ui.view">
        <field name="name">ha.well.threshold.search</field>
        <field name="model">ha.well.threshold</field>
        <field name="arch" type="xml">
            <search string="WELL IEQ Thresholds">
                <field name="name"/>
                <field name="well_feature"/>
                <field name="parameter_type"/>
                <field name="entity_id"/>
                <filter name="active" string="Active" domain="[('active', '=', True)]"/>
                <separator/>
                <filter name="compliant" string="Compliant" domain="[('compliance_status', '=', 'compliant')]"/>
                <filter name="non_compliant" string="Non-Compliant" domain="[('compliance_status', '=', 'non_compliant')]"/>
                <filter name="no_data" string="No Data" domain="[('compliance_status', '=', 'no_data')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_feature" string="WELL Feature" context="{'group_by': 'well_feature'}"/>
                    <filter name="group_by_type" string="Parameter Type" context="{'group_by': 'parameter_type'}"/>
                    <filter name="group_by_status" string="Status" context="{'group_by': 'compliance_status'}"/>
                    <filter name="group_by_instance" string="HA Instance" context="{'group_by': 'instance_id'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>
