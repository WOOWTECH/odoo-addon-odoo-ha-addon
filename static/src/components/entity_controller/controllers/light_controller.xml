<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <!-- Light Domain Controller -->
    <t t-name="odoo_ha_addon.EntityController.Light">
        <div class="light-controller">
            <div class="d-flex align-items-center gap-3">
                <div class="form-check form-switch entity-large-switch entity-light-switch">
                    <input
                        class="form-check-input"
                        type="checkbox"
                        role="switch"
                        t-att-checked="isOn"
                        t-att-disabled="state.isLoading"
                        t-att-class="{'entity-loading': state.isLoading}"
                        t-on-click.stop.prevent="() => this.onToggle()"
                    />
                </div>
                <i class="fa fa-lightbulb-o fa-lg" t-att-class="{'text-warning': isOn, 'text-muted': isOff}"/>
            </div>

            <!-- Brightness slider (only when light is on and has brightness) -->
            <t t-if="isOn and state.attributes?.brightness !== undefined">
                <div class="brightness-control entity-value-slider entity-brightness-slider mt-3">
                    <div class="slider-track-container d-flex align-items-center gap-2">
                        <i class="fa fa-adjust text-muted"/>
                        <input
                            type="range"
                            min="0"
                            max="255"
                            step="1"
                            t-att-value="currentBrightness"
                            t-att-style="'--slider-progress: ' + Math.round((currentBrightness / 255) * 100) + '%'"
                            t-on-input.stop="(ev) => this.onBrightnessInput(ev.target.value)"
                            t-on-change.stop="(ev) => this.onSetBrightness(ev.target.value)"
                            t-att-disabled="state.isLoading"
                        />
                        <span class="slider-value-badge">
                            <t t-esc="Math.round((currentBrightness / 255) * 100)"/>%
                        </span>
                    </div>
                </div>
            </t>

            <!-- Color temperature slider (only when light is on and supports color_temp) -->
            <t t-if="isOn and state.attributes?.supported_color_modes?.includes('color_temp') and state.attributes?.min_color_temp_kelvin">
                <div class="color-temp-control entity-value-slider entity-color-temp-slider mt-3">
                    <div class="slider-track-container d-flex align-items-center gap-2">
                        <i class="fa fa-fire text-muted" title="Warm"/>
                        <input
                            type="range"
                            t-att-min="state.attributes.min_color_temp_kelvin"
                            t-att-max="state.attributes.max_color_temp_kelvin"
                            step="50"
                            t-att-value="currentColorTemp"
                            t-att-style="'--slider-progress: ' + Math.round(((currentColorTemp - state.attributes.min_color_temp_kelvin) / (state.attributes.max_color_temp_kelvin - state.attributes.min_color_temp_kelvin)) * 100) + '%'"
                            t-on-input.stop="(ev) => this.onColorTempInput(ev.target.value)"
                            t-on-change.stop="(ev) => this.onSetColorTemp(ev.target.value)"
                            t-att-disabled="state.isLoading"
                        />
                        <i class="fa fa-snowflake-o text-muted" title="Cool"/>
                        <span class="slider-value-badge">
                            <t t-esc="currentColorTemp"/>K
                        </span>
                    </div>
                </div>
            </t>

            <!-- RGB Color picker (only when light is on and supports rgb/hs/xy color modes) -->
            <t t-if="isOn and state.attributes?.supported_color_modes and this.supportsRgbColor">
                <div class="rgb-color-control mt-3">
                    <div class="d-flex align-items-center gap-2">
                        <i class="fa fa-paint-brush text-muted"/>
                        <label class="form-label mb-0 small text-muted" string="Color">Color</label>
                        <input
                            type="color"
                            class="form-control form-control-color"
                            t-att-value="currentRgbHex"
                            t-on-change.stop="(ev) => this.onSetRgbColor(ev.target.value)"
                            t-att-disabled="state.isLoading"
                            title="Choose light color"
                        />
                        <span class="slider-value-badge" t-if="state.attributes?.rgb_color">
                            RGB(<t t-esc="state.attributes.rgb_color[0]"/>,<t t-esc="state.attributes.rgb_color[1]"/>,<t t-esc="state.attributes.rgb_color[2]"/>)
                        </span>
                    </div>
                </div>
            </t>

            <!-- Effect dropdown (only when light has effect_list) -->
            <t t-if="isOn and state.attributes?.effect_list?.length > 0">
                <div class="effect-control mt-3">
                    <div class="d-flex align-items-center gap-2">
                        <i class="fa fa-magic text-muted"/>
                        <label class="form-label mb-0 small text-muted" string="Effect">Effect</label>
                        <select
                            class="form-select form-select-sm"
                            t-att-value="state.attributes?.effect || ''"
                            t-on-change.stop="(ev) => this.onSetEffect(ev.target.value)"
                            t-att-disabled="state.isLoading"
                        >
                            <option value="" disabled="" string="Select effect">Select effect</option>
                            <t t-foreach="state.attributes.effect_list" t-as="effect" t-key="effect">
                                <option t-att-value="effect" t-att-selected="state.attributes?.effect === effect">
                                    <t t-esc="effect"/>
                                </option>
                            </t>
                        </select>
                    </div>
                </div>
            </t>
        </div>
    </t>
</templates>
