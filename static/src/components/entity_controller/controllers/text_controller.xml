<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <!-- Text Domain Controller (input_text / text) -->
    <t t-name="odoo_ha_addon.EntityController.Text">
        <div class="text-controller d-flex align-items-center gap-2">
            <i class="fa fa-pencil fa-lg text-muted"/>
            <input
                type="text"
                class="form-control"
                t-att-value="state.entityState"
                t-att-disabled="state.isLoading"
                t-att-minlength="state.attributes?.min || 0"
                t-att-maxlength="state.attributes?.max || 255"
                t-att-pattern="state.attributes?.pattern || ''"
                t-on-keydown="(ev) => { if(ev.key === 'Enter') this.onSetValue(ev.target.value); }"
            />
            <button class="btn btn-primary btn-sm"
                t-on-click.stop="(ev) => this.onSetValue(ev.target.closest('.text-controller').querySelector('input').value)"
                t-att-disabled="state.isLoading">
                <i class="fa fa-check"/>
            </button>
        </div>
    </t>
</templates>
