<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <!-- Todo Domain Controller -->
    <t t-name="odoo_ha_addon.EntityController.Todo">
        <div class="todo-controller">
            <div class="d-flex align-items-center gap-3 mb-3">
                <i class="fa fa-tasks fa-lg text-primary"/>
                <span class="badge bg-secondary"><t t-esc="state.entityState"/></span>
            </div>
            <div class="d-flex align-items-center gap-2">
                <input type="text" class="form-control form-control-sm"
                    placeholder="New item..."
                    t-att-disabled="state.isLoading"
                    t-on-keydown="(ev) => ev.key === 'Enter' &amp;&amp; ev.target.value &amp;&amp; (this.onAddItem(ev.target.value), ev.target.value='')"
                />
                <button class="btn btn-primary btn-sm"
                    t-on-click.stop="(ev) => { const input = ev.target.closest('.todo-controller').querySelector('input'); input.value &amp;&amp; (this.onAddItem(input.value), input.value=''); }"
                    t-att-disabled="state.isLoading">
                    <i class="fa fa-plus"/>
                </button>
            </div>
        </div>
    </t>
</templates>
