<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <!-- Alarm Control Panel Domain Controller -->
    <t t-name="odoo_ha_addon.EntityController.AlarmControlPanel">
        <div class="alarm-controller">
            <div class="d-flex align-items-center gap-3 mb-3">
                <i class="fa fa-shield fa-lg" t-att-class="{
                    'text-success': state.entityState === 'disarmed',
                    'text-danger': state.entityState === 'triggered',
                    'text-warning': state.entityState.startsWith('armed'),
                    'text-muted': state.entityState === 'unavailable'
                }"/>
                <span class="badge fs-6" t-att-class="{
                    'bg-success': state.entityState === 'disarmed',
                    'bg-danger': state.entityState === 'triggered',
                    'bg-warning': state.entityState.startsWith('armed'),
                    'bg-secondary': !state.entityState.startsWith('armed') &amp;&amp; state.entityState !== 'disarmed' &amp;&amp; state.entityState !== 'triggered'
                }">
                    <t t-esc="state.entityState"/>
                </span>
            </div>

            <div class="d-flex flex-wrap gap-2">
                <button class="btn btn-outline-success btn-sm"
                    t-on-click.stop="() => this.onDisarm()" t-att-disabled="state.isLoading">
                    <i class="fa fa-unlock me-1"/>Disarm
                </button>
                <button class="btn btn-outline-warning btn-sm"
                    t-on-click.stop="() => this.onArmHome()" t-att-disabled="state.isLoading">
                    <i class="fa fa-home me-1"/>Arm Home
                </button>
                <button class="btn btn-outline-danger btn-sm"
                    t-on-click.stop="() => this.onArmAway()" t-att-disabled="state.isLoading">
                    <i class="fa fa-car me-1"/>Arm Away
                </button>
                <button class="btn btn-outline-info btn-sm"
                    t-on-click.stop="() => this.onArmNight()" t-att-disabled="state.isLoading">
                    <i class="fa fa-moon-o me-1"/>Arm Night
                </button>
            </div>
        </div>
    </t>
</templates>
